# MacBookPro13 Linux setup configuration.
# Set any RUN_* value to 0 to skip that module.

RUN_MISC=1
RUN_WIFI=1
RUN_SOUND=1
RUN_TOUCHBAR_CAMERA=1
RUN_SUSPEND=1

# This repo is intentionally opinionated for my own fresh installs.
# Full-user NOPASSWD sudo is convenient but reduces local security.
PASSWORDLESS_SUDO=1
SUDOERS_MODE=full-user-nopasswd

WIFI_COUNTRY=BE
WIFI_TEMPLATE=assets/wifi/brcmfmac43602-pcie.template.txt

TOUCHBAR_FNMODE=1
TOUCHBAR_IDLE_TIMEOUT=-1
TOUCHBAR_DIM_TIMEOUT=-1

# s2idle avoids the black-screen resume failure seen on this MacBookPro13,3.
# deep may save more power, but can leave the internal display off after wake.
SUSPEND_MEMORY_SLEEP=s2idle

WORK_DIR=/var/lib/mbp13-linux-setup
BACKUP_DIR=/var/backups/mbp13-linux-setup
LOG_FILE=/tmp/mbp13-linux-setup.log
